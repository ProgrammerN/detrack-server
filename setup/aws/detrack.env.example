# Detrack server secrets and overrides (not committed to git).
# Copy to /opt/detrack/conf/detrack.env on the server.
#
# Google reverse geocoding uses the Geocoding API (not Places API):
# https://developers.google.com/maps/documentation/geocoding
# Enable "Geocoding API" on your Google Cloud project and restrict the key by IP.
CONFIG_USE_ENVIRONMENT_VARIABLES=true
GEOCODER_KEY=
# Firebase service account: use configure-firebase-push.sh (writes /opt/detrack/conf/firebase-service-account.json).
