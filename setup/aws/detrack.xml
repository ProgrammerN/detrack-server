<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE properties SYSTEM 'http://java.sun.com/dtd/properties.dtd'>
<properties>

    <!-- Documentation: https://www.traccar.org/configuration-file/ -->

    <entry key='config.useEnvironmentVariables'>true</entry>

    <entry key='web.path'>/opt/detrack/web</entry>
    <entry key='web.localizationPath'>/opt/detrack/templates/translations</entry>
    <entry key='web.port'>8082</entry>

    <entry key='media.path'>/opt/detrack/data/media</entry>

    <entry key='logger.file'>/opt/detrack/logs/tracker-server.log</entry>

    <!-- Embedded H2 keeps costs low (no separate RDS instance). -->
    <entry key='database.driver'>org.h2.Driver</entry>
    <entry key='database.url'>jdbc:h2:/opt/detrack/data/database</entry>
    <entry key='database.user'>sa</entry>
    <entry key='database.password' />

    <!-- Data-first FCM so the Android app always receives onMessageReceived -->
    <entry key='notificator.types'>web,mail,command,firebase</entry>
    <entry key='notificator.firebase.mode'>data</entry>
    <!-- Service account JSON file (configure-firebase-push.sh). Do not use detrack.env — systemd breaks \n in keys. -->
    <entry key='notificator.firebase.serviceAccountFile'>/opt/detrack/conf/firebase-service-account.json</entry>

    <!-- Reverse geocoding: https://www.traccar.org/reverse-geocoding/ -->
    <!-- Set GEOCODER_KEY in /opt/detrack/conf/detrack.env (Google Geocoding API key). -->
    <entry key='geocoder.enable'>true</entry>
    <entry key='geocoder.type'>google</entry>
    <!-- Only geocode on report/address requests to control API cost -->
    <entry key='geocoder.onRequest'>true</entry>
    <!-- Skip lookup if device moved less than 50 meters since last address -->
    <entry key='geocoder.reuseDistance'>50</entry>
    <entry key='geocoder.cacheSize'>1000</entry>

</properties>
